# Echo Worker – production env template. Copy to .env and set values. Do not commit .env.

# Required: PostgreSQL (same DB as API)
ECHO_DATABASE_URL=postgresql://user:password@host:5432/echo

# Chunk storage: leave unset to use local disk (api/Data/Chunks). Set when API uses MinIO.
# ECHO_CHUNK_BASE_PATH=
ECHO_MINIO_ENDPOINT=
ECHO_MINIO_ACCESS_KEY=
ECHO_MINIO_SECRET_KEY=
ECHO_MINIO_BUCKET=echo-raw-audio

# Worker HTTP server
ECHO_WORKER_PORT=5050

# Whisper (optional – defaults are production-friendly)
# ECHO_WHISPER_MODEL=medium
# ECHO_WHISPER_DEVICE=cuda
# ECHO_WHISPER_COMPUTE_TYPE=float16
# ECHO_TRANSCRIPT_INCLUDE_TIMESTAMPS=true

# Long recordings
# ECHO_WHISPER_SEGMENT_MINUTES=10
# ECHO_SUMMARY_MAX_CHUNKS=12

# Logging: INFO, WARNING, ERROR, DEBUG
LOG_LEVEL=INFO

# Optional: Hugging Face token (faster model downloads, no warning)
# HF_TOKEN=
